# ─── Anthropic ───────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Meta Graph API ──────────────────────────────────────────
# Page Access Token (no User Token) — generado desde Meta Business Suite
# Permisos requeridos: pages_manage_posts, instagram_basic, instagram_content_publish
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de tu cuenta de Instagram Business
# Encuéntralo en: GET /me/accounts → busca tu página → GET /{page-id}?fields=instagram_business_account
INSTAGRAM_BUSINESS_ACCOUNT_ID=1234567890

# ID de tu página de Facebook
# Encuéntralo en: https://www.facebook.com/xxxxxxxxxx/about → Información de la página
FACEBOOK_PAGE_ID=0987654321

# ─── Servidor ────────────────────────────────────────────────
PORT=3001

# URL pública del servidor — requerida para Instagram (necesita descargar la imagen)
# En desarrollo: usa ngrok → ngrok http 3001 → copia la URL https://xxxx.ngrok.io
# En producción: tu dominio real → https://tudominio.com
PUBLIC_URL=https://xxxx.ngrok.io
